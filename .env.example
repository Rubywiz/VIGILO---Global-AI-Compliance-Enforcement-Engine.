# VIGILO Environment Configuration
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (for document and code analysis)
# Get one at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Featherless API Key (for scoring against EU AI Act articles)
# Get one at: https://featherless.ai
FEATHERLESS_API_KEY=your-featherless-api-key

# Speechmatics API Key (for voice transcription)
# Get one at: https://portal.speechmatics.com
SPEECHMATICS_API_KEY=your-speechmatics-api-key
